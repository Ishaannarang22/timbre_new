# Copy to .env and fill in. .env is git-ignored.

# NVIDIA API key from https://build.nvidia.com (free NVIDIA Developer Program).
# Looks like: nvapi-xxxxxxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Deepgram key (STT) — https://console.deepgram.com (free tier, no card).
DEEPGRAM_API_KEY=REPLACE_ME
# Cartesia key (TTS, expressive Sonic voices) — https://play.cartesia.ai
CARTESIA_API_KEY=REPLACE_ME
# Voice — fill in ONE id below to override the code default (Brooke). Shortlist:
#   Brooke – Big Sister ......... e07c00bc-4134-4eae-9ea4-1a55fb45746b  (default · confident female)
#   Lauren – Lively Narrator .... a33f7a4c-100f-41cf-a1fd-5822e8fc253f  (expressive female)
#   Blake – Helpful Agent ....... a167e0f3-df7e-4d52-a9c3-f949145efdab  (energetic male)
#   Jacqueline – Reassuring ..... 9626c31c-bec5-4cca-baa8-f8ba9e84c8bc  (empathic female)
#   Cooper – Friendly Mate ...... 49743b08-0f5d-4741-839c-b12933853780  (warm male)
#   Rupert – Caring Dad ......... 0ad65e7f-006c-47cf-bd31-52279d487913  (warm mature male)
CARTESIA_VOICE_ID=
# Speaking rate — range ~0.6 (slow/warm) to ~1.5 (fast), default 0.95 (deliberate coaching pace).
# Lower = slower and warmer; higher = more energetic. Leave blank to use code default.
CARTESIA_SPEED=

# --- Turn-taking / endpointing (when the bot decides you're done talking) ---
# SMART_TURN_THRESHOLD: confidence (0-1) the Smart Turn model needs before ENDING
#   your turn. Higher = more patient (won't cut you off mid-sentence), default 0.7.
#   Lower = snappier but more interruptive. THIS is the main "stop interrupting me" dial.
# VAD_STOP_SECS: seconds of silence before we even ASK the model (default 0.2). Keep short.
# SMART_TURN_STOP_SECS: hard ceiling — force-end the turn after this much CONTINUOUS silence,
#   even if the model is unsure (default 2.0). This is your worst-case dead-air when you finished
#   but sounded ambiguous. Pairs with the threshold: high threshold = don't interrupt; low ceiling
#   = but don't stall if I'm actually done.
SMART_TURN_THRESHOLD=
VAD_STOP_SECS=
SMART_TURN_STOP_SECS=

# --- Added at Milestone 1 (Twilio phone) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- Caller authorization (M3+ Mac-control tools) ---
# The phone agent only offers its Mac-control tools (volume, music, files, apps, the GLM tool
# factory, cross-call memory, …) to an AUTHORIZED caller. The 7 AM OUTBOUND call is always
# authorized (we dialed you). An INBOUND call is authorized ONLY if the caller's number is on
# this allowlist; anyone else gets a friendly chat-only "no tools" persona (it can't touch your
# Mac). Comma-separated E.164 numbers (e.g. +14155550100,+18005551212). Numbers are normalized
# for comparison, so spacing/formatting doesn't matter. Caller ID can be spoofed, so this is
# access-control, not crypto — the per-call ws token still blocks non-Twilio scanners.
# If AUTHORIZED_CALLERS is unset, it defaults to TARGET_PHONE_NUMBER (your own number).
# AUTHORIZED_CALLERS=
# TARGET_PHONE_NUMBER=

# --- Dynamic tool factory (M4: request_new_tool builds a tool mid-call via GLM-5.1) ---
# Z.AI / GLM-5.1 credentials, used ONLY by mac_tools/factory.py when the agent has no tool for
# a request and authors one on the fly. NEVER used in the voice hot path. Leave unset to disable
# tool creation (request_new_tool then politely reports it can't build it).
# ZAI_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# ZAI_MODEL=glm-5.1
